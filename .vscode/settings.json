{
    "python.testing.unittestArgs": [
        "-v",
        "-s",
        ".",
        "-p",
        "*test.py"
    ],
    "python.testing.pytestEnabled": false,
    "python.testing.unittestEnabled": true,
    
    "workbench.activityBar.location": "top",
    "workbench.sideBar.location": "right",
    "workbench.panel.defaultLocation": "top",
    "workbench.secondarySideBar.visible": false,
    "workbench.sideBar.visible": false,
    "editor.cursorBlinking": "expand",
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.smoothScrolling": true,

    "workbench.colorCustomizations": {
        "terminal.background": "#14101e",
        "terminal.foreground": "#00f0ff",
        "terminal.cursor.foreground": "#ff007f",
        "terminal.ansiGreen": "#39ff14",
        "terminal.ansiBlue": "#00bfff",
        "terminal.selectionBackground": "#ff007f44",
        
        // --- Scrollbar Colors (Aapki Cyberpunk/Neon theme ke hisab se) ---
        "scrollbarSlider.background": "#00f0ff55",      // Normal: Neon Cyan (Thoda transparent)
        "scrollbarSlider.hoverBackground": "#00f0ffaa", // Hover: Tez Cyan
        "scrollbarSlider.activeBackground": "#ff007f"    // Click karne par: Hot Pink
    },
    
    "terminal.integrated.cursorStyle": "block",
    "terminal.integrated.cursorBlinking": true,
    "terminal.integrated.fontSize": 14,
    "terminal.integrated.fontWeight": "bold",
    "terminal.integrated.lineHeight": 1.3,
    "terminal.integrated.letterSpacing": 0.6,

    "terminal.integrated.shellIntegration.enabled": false,
    "terminal.integrated.copyOnSelection": true,

    // --- Scrollbar Size aur Visibility ---
    "editor.scrollbar.vertical": "visible",
    "editor.scrollbar.verticalScrollbarSize": 100

}
